---
// Animated nonagram compass from WF-A design handoff.
// Two counter-rotating groups (.rotor clockwise 120s, .rotor-rev counter-clockwise 180s).
// prefers-reduced-motion halts both via base.css.
---

<section class="sigil-section reveal">
  <div class="sig-head">
    <span>§·01 · NONAGRAM · RECURSIVE {9/4} {9/3} {9/2}</span>
    <span class="t2">φ-NESTED · 440 / 272 / 168 / 104 / 64</span>
    <span class="t3">9 POINTS · 8 AXES · 6 RINGS</span>
  </div>

  <div class="sigil-stage">
    <svg class="sig" viewBox="0 0 1000 1000" aria-hidden="true">
      <g>
        <circle class="ring r-outer" cx="500" cy="500" r="480"></circle>
        <circle class="ring" cx="500" cy="500" r="440"></circle>
        <circle class="ring" cx="500" cy="500" r="271.9"></circle>
        <circle class="ring" cx="500" cy="500" r="168.1"></circle>
        <circle class="ring" cx="500" cy="500" r="103.9"></circle>
        <circle class="ring" cx="500" cy="500" r="64.2"></circle>
      </g>
      <g>
        <line class="axis" x1="500" y1="500" x2="500" y2="0"></line>
        <line class="axis" x1="500" y1="500" x2="853.6" y2="146.4"></line>
        <line class="axis" x1="500" y1="500" x2="1000" y2="500"></line>
        <line class="axis" x1="500" y1="500" x2="853.6" y2="853.6"></line>
        <line class="axis" x1="500" y1="500" x2="500" y2="1000"></line>
        <line class="axis" x1="500" y1="500" x2="146.4" y2="853.6"></line>
        <line class="axis" x1="500" y1="500" x2="0" y2="500"></line>
        <line class="axis" x1="500" y1="500" x2="146.4" y2="146.4"></line>
      </g>
      <g class="rotor">
        <path
          class="star primary"
          d="M500 60 L 650.5 913.5 L 217.2 162.9 L 881.1 720 L 66.7 423.6 L 933.3 423.6 L 118.9 720 L 782.8 162.9 L 349.5 913.5 L 500 60"
        ></path>
      </g>
      <g class="rotor-rev">
        <path
          class="star s2"
          d="M500 228.1 L 593 755.5 L 325.2 291.7 L 735.5 636 L 232.2 452.8 L 767.8 452.8 L 264.5 636 L 674.8 291.7 L 407 755.5 L 500 228.1"
        ></path>
      </g>
      <g class="rotor-rev">
        <path
          class="star s4"
          d="M500 396.1 L 602.3 482 L 535.5 597.6 L 410 551.9 L 433.2 420.4 L 566.8 420.4 L 590 551.9 L 464.5 597.6 L 397.7 482 L 500 396.1"
        ></path>
      </g>
      <g class="rotor">
        <path
          class="star s5"
          d="M500 435.8 L 563.2 488.9 L 522 560.3 L 444.4 532.1 L 458.7 450.8 L 541.3 450.8 L 555.6 532.1 L 478 560.3 L 436.8 488.9 L 500 435.8"
        ></path>
      </g>
      <g>
        <text class="lbl-deg" x="500" y="-4" text-anchor="middle">0°</text>
        <text class="lbl-deg" x="860.6" y="145.4" text-anchor="middle">45°</text>
        <text class="lbl-deg" x="1010" y="506" text-anchor="middle">90°</text>
        <text class="lbl-deg" x="860.6" y="866.6" text-anchor="middle">135°</text>
        <text class="lbl-deg" x="500" y="1016" text-anchor="middle">180°</text>
        <text class="lbl-deg" x="139.4" y="866.6" text-anchor="middle">225°</text>
        <text class="lbl-deg" x="-10" y="506" text-anchor="middle">270°</text>
        <text class="lbl-deg" x="139.4" y="145.4" text-anchor="middle">315°</text>
      </g>
      <g>
        <text class="lbl-tick" x="506" y="133.3">5</text>
        <text class="lbl-tick" x="506" y="206.7">10</text>
        <text class="lbl-tick" x="506" y="280">15</text>
        <text class="lbl-tick" x="506" y="353.3">20</text>
        <text class="lbl-tick" x="506" y="426.7">25</text>
      </g>
    </svg>
    <div class="sigil-caption">
      <div class="c-top">⌁ KNOT · YOUR · KIND ⌁</div>
      <div class="c-num">THE <em>NINE</em></div>
      <div class="c-sub">φ · 1.6180339887 · 9·POINTS</div>
    </div>
  </div>

  <div class="sig-foot">
    <div class="cell"><div class="k">OUTER · {9/4}</div><div class="v">R = 440 · bold red star</div></div>
    <div class="cell"><div class="k">NESTED · φ·SCALE</div><div class="v">r · φ⁻¹, φ⁻², φ⁻³, φ⁻⁴</div></div>
    <div class="cell"><div class="k">COMPASS</div><div class="v">0° → 315° · 8·AXES</div></div>
  </div>
</section>

<style>
  .sigil-section {
    position: relative;
    padding: var(--f-144) 0;
    border-top: 1px solid var(--rust-dim);
    border-bottom: 1px solid var(--rust-dim);
    overflow: hidden;
    background:
      radial-gradient(ellipse 60% 80% at 50% 50%, rgba(225, 6, 0, 0.08), transparent 70%),
      #000;
  }
  .sigil-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 50%, rgba(155, 255, 58, 0.18) 0.5px, transparent 1px),
      radial-gradient(circle at 30% 70%, rgba(184, 77, 255, 0.14) 0.5px, transparent 1px);
    background-size: 5px 5px, 8px 8px;
    mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, #000 0%, rgba(0, 0, 0, 0.5) 45%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 55% 55% at 50% 50%, #000 0%, rgba(0, 0, 0, 0.5) 45%, transparent 80%);
    pointer-events: none;
  }

  .sig-head {
    position: absolute;
    top: var(--f-55);
    left: var(--f-144);
    right: var(--f-144);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--f-21);
    font: 400 11px/1.3 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    z-index: 3;
    flex-wrap: wrap;
  }
  .sig-head .t2 { color: var(--viol); }
  .sig-head .t3 { color: var(--acid); }

  .sigil-stage {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .sig {
    width: min(900px, 92vw);
    height: auto;
    aspect-ratio: 1;
    display: block;
    filter: drop-shadow(0 0 18px rgba(225, 6, 0, 0.35));
  }

  .sig :global(.ring) { fill: none; stroke: var(--viol-dim); stroke-width: 0.6; }
  .sig :global(.ring.r-outer) { stroke: var(--rust); stroke-width: 1; opacity: 0.85; }
  .sig :global(.axis) { stroke: var(--viol); stroke-width: 0.5; stroke-dasharray: 4 5; opacity: 0.7; }
  .sig :global(.star) { fill: none; stroke-linejoin: miter; stroke-linecap: butt; }
  .sig :global(.star.primary) {
    stroke: var(--rust);
    stroke-width: 9;
    filter: drop-shadow(0 0 10px rgba(225, 6, 0, 0.55));
  }
  .sig :global(.star.s2) { stroke: var(--viol); stroke-width: 1.1; opacity: 0.85; }
  .sig :global(.star.s4) {
    stroke: var(--acid);
    stroke-width: 0.8;
    opacity: 0.6;
    filter: drop-shadow(0 0 3px var(--acid));
  }
  .sig :global(.star.s5) { stroke: var(--viol); stroke-width: 0.6; opacity: 0.5; }
  .sig :global(.lbl-deg) { font: 400 18px/1 var(--font-mono); fill: var(--rust); letter-spacing: 0.04em; }
  .sig :global(.lbl-tick) { font: 400 11px/1 var(--font-mono); fill: var(--viol); opacity: 0.7; }

  .sig :global(.rotor) {
    animation: sigil-rotate 120s linear infinite;
    transform-origin: 500px 500px;
  }
  .sig :global(.rotor-rev) {
    animation: sigil-rotate-rev 180s linear infinite;
    transform-origin: 500px 500px;
  }
  @keyframes sigil-rotate {
    from { transform: rotate(0); }
    to { transform: rotate(360deg); }
  }
  @keyframes sigil-rotate-rev {
    from { transform: rotate(0); }
    to { transform: rotate(-360deg); }
  }

  .sigil-caption {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
    text-align: center;
    pointer-events: none;
  }
  .sigil-caption .c-top {
    font: 400 11px/1 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: var(--f-13);
  }
  .sigil-caption .c-num {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(64px, 14vw, 144px);
    line-height: 0.9;
    letter-spacing: 0.04em;
    color: var(--bone);
    text-shadow: 0 0 24px rgba(0, 0, 0, 0.9);
  }
  .sigil-caption .c-num em {
    font-style: normal;
    background: linear-gradient(92deg, var(--acid), var(--viol));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 0 14px rgba(184, 77, 255, 0.4));
  }
  .sigil-caption .c-sub {
    margin-top: var(--f-13);
    font: 400 11px/1.3 var(--font-mono);
    color: var(--bone-dim);
    letter-spacing: 0.28em;
    text-transform: uppercase;
  }

  .sig-foot {
    position: absolute;
    bottom: var(--f-55);
    left: var(--f-144);
    right: var(--f-144);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--f-55);
    z-index: 3;
    pointer-events: none;
  }
  .sig-foot .cell { border-top: 1px solid var(--rust-dim); padding-top: var(--f-13); }
  .sig-foot .k { font: 400 11px/1 var(--font-mono); color: var(--rust); letter-spacing: 0.22em; }
  .sig-foot .v {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 21px;
    color: var(--bone);
    margin-top: 8px;
    letter-spacing: 0.04em;
  }
  .sig-foot .cell:nth-child(2) .k { color: var(--viol); }
  .sig-foot .cell:nth-child(3) .k { color: var(--acid); }

  @media (max-width: 1000px) {
    .sig-head,
    .sig-foot {
      position: static;
      padding: 0 var(--f-21);
      margin: var(--f-34) 0;
    }
    .sig-foot {
      grid-template-columns: 1fr;
      gap: var(--f-21);
    }
    .sigil-section {
      padding: var(--f-55) 0;
    }
  }
</style>
