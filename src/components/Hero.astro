---
// WF-A Meridian hero: φ-split diagrammatic hero with boxed wordmark + tribute chip.
// Responsive adaptation: hero keeps 1597:987 aspect up to max-width 1597px,
// scales down on smaller viewports while preserving the φ-split geometry.
---

<section class="hero reveal">
  <div class="stipple-bg" aria-hidden="true"></div>
  <div class="nonagon" aria-hidden="true">
    <svg viewBox="0 0 1597 987" preserveAspectRatio="xMidYMid meet">
      <g transform="translate(798.5 493.5)">
        <polygon class="edge" points="0,-400 257,-307 394,-68 343,197 140,380 -140,380 -343,197 -394,-68 -257,-307"></polygon>
        <polygon class="edge v" points="0,-247 159,-190 244,-42 212,122 86,235 -86,235 -212,122 -244,-42 -159,-190"></polygon>
        <g class="edge">
          <line x1="0" y1="-400" x2="0" y2="380"></line>
          <line x1="-394" y1="-68" x2="394" y2="-68"></line>
          <line x1="-343" y1="197" x2="343" y2="197"></line>
          <line x1="-257" y1="-307" x2="257" y2="-307"></line>
        </g>
        <g class="edge v">
          <line x1="0" y1="-400" x2="140" y2="380"></line>
          <line x1="0" y1="-400" x2="-140" y2="380"></line>
          <line x1="257" y1="-307" x2="-343" y2="197"></line>
          <line x1="-257" y1="-307" x2="343" y2="197"></line>
          <line x1="394" y1="-68" x2="-343" y2="197"></line>
          <line x1="-394" y1="-68" x2="343" y2="197"></line>
        </g>
      </g>
    </svg>
  </div>
  <div class="grain" aria-hidden="true"></div>

  <nav class="nav" aria-label="Primary">
    <a href="#top" class="mark">⌁ KNOT·YOUR·KIND</a>
    <ul>
      <li><a href="#the-nine">THE NINE</a></li>
      <li><a href="#tour">TOUR</a></li>
      <li><a href="#gallery">GALLERY</a></li>
      <li><a href="#booking">BOOKING</a></li>
    </ul>
  </nav>

  <div class="stamp-tl">
    <span>⌁ KNOT·YOUR·KIND</span>
    <span>A TRIBUTE TO SLIPKNOT</span>
  </div>
  <div class="stamp-tr">
    <span>CAROLINAS · USA</span>
    <span>φ · 1.6180339887</span>
  </div>

  <div class="lbl-split">← φ SPLIT →</div>

  <div class="ruler-top" aria-hidden="true"></div>
  <div class="ruler-split" aria-hidden="true"></div>
  <div class="ruler-bot" aria-hidden="true"></div>

  <div class="wm-box">
    <span class="wm">KNOT YOUR KIND</span>
  </div>

  <div class="trib-box">
    <span class="t">A&nbsp;&nbsp;TRIBUTE&nbsp;&nbsp;TO</span>
    <span class="tmark">the&nbsp;nine</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    max-width: var(--f-1597);
    aspect-ratio: 1597 / 987;
    margin: 0 auto;
    background: var(--ink);
    overflow: hidden;
    /* container-type lets children size against the artboard width instead of viewport */
    container-type: inline-size;
  }

  /* Ruler lines — positioned with percentages to scale with the artboard */
  .ruler-top {
    position: absolute;
    left: 11.9%;
    right: 11.9%;
    top: 8.1%;
    height: 1px;
    background: var(--rust);
  }
  .ruler-split {
    position: absolute;
    left: 0;
    right: 0;
    top: 49.6%;
    height: 1px;
    background: var(--rust);
  }
  .ruler-bot {
    position: absolute;
    left: 19.4%;
    right: 19.4%;
    bottom: 18.0%;
    height: 1px;
    background: var(--rust);
  }

  .lbl-split {
    position: absolute;
    top: 46.8%;
    right: 2.1%;
    font: 400 12px/1 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.1em;
  }

  /* Corner stamps */
  .stamp-tl,
  .stamp-tr {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font: 400 11px/1.3 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    z-index: 5;
  }
  .stamp-tl { top: 2.8%; left: 2.1%; }
  .stamp-tr { top: 2.8%; right: 2.1%; text-align: right; }
  .stamp-tl span:first-child,
  .stamp-tr span:last-child {
    color: var(--rust);
    letter-spacing: 0.22em;
  }

  /* Navigation */
  .nav {
    position: absolute;
    top: 5.6%;
    left: 2.1%;
    right: 2.1%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font: 400 11px/1 var(--font-mono);
    color: var(--bone-dim);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    z-index: 6;
  }
  .nav .mark {
    color: var(--rust);
    letter-spacing: 0.3em;
  }
  .nav ul {
    display: flex;
    gap: var(--f-34);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav ul li a {
    transition: color 140ms;
  }
  .nav ul li a:hover {
    color: var(--bone);
  }

  /* Wordmark box — 130px tall on 987px canvas = 13.2% */
  .wm-box {
    position: absolute;
    top: 11.1%;
    left: 11.9%;
    right: 11.9%;
    height: 13.2%;
    border: 1px solid var(--bone);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ink);
  }
  .wm {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(28px, 4.5cqi, 72px);
    letter-spacing: 0.52em;
    color: var(--bone);
    white-space: nowrap;
    padding-left: 0.52em;
  }

  /* Tribute chip */
  .trib-box {
    position: absolute;
    bottom: 15.0%;
    left: 19.4%;
    right: 19.4%;
    height: 9.1%;
    border: 1px solid var(--rust);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--f-21);
    background: var(--ink);
  }
  .trib-box::before {
    content: '';
    position: absolute;
    inset: -3px;
    border: 1px solid transparent;
    background: linear-gradient(90deg, var(--acid), transparent 30%, transparent 70%, var(--viol)) border-box;
    -webkit-mask: linear-gradient(#000 0 0) padding-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.6;
  }
  .trib-box .t {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(14px, 2.1cqi, 34px);
    letter-spacing: 0.42em;
    color: var(--bone);
  }
  .trib-box .tmark {
    font-size: clamp(18px, 2.8cqi, 44px);
  }

  /* Tribute mark — stylized "the nine" (our original mark, not a logo copy) */
  .tmark {
    display: inline-block;
    color: var(--acid);
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.02em;
    transform: skewX(-12deg);
    position: relative;
    text-shadow:
      -1.5px 0 0 var(--viol),
      1.5px 0 0 var(--acid),
      0 0 12px rgba(155, 255, 58, 0.6),
      0 0 18px rgba(184, 77, 255, 0.4);
    animation: chromasplit 3.2s steps(20, end) infinite;
  }
  .tmark::before,
  .tmark::after {
    content: '';
    position: absolute;
  }
  .tmark::before {
    left: -6px;
    top: 15%;
    width: 3px;
    height: 70%;
    transform: skewX(6deg);
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
  }
  .tmark::after {
    right: -6px;
    top: 10%;
    width: 2px;
    height: 80%;
    transform: skewX(-8deg);
    background: var(--viol);
    box-shadow: 0 0 8px var(--viol);
  }
  @keyframes chromasplit {
    0%, 88%, 100% {
      text-shadow:
        -1.5px 0 0 var(--viol),
        1.5px 0 0 var(--acid),
        0 0 12px rgba(155, 255, 58, 0.6),
        0 0 18px rgba(184, 77, 255, 0.4);
    }
    90% {
      text-shadow:
        -3px 0 0 var(--viol),
        3px 0 0 var(--acid),
        0 0 20px var(--acid),
        0 0 28px var(--viol);
    }
    94% {
      text-shadow:
        2px 0 0 var(--viol),
        -2px 0 0 var(--acid),
        0 0 14px var(--viol);
    }
  }

  /* Backdrop layers */
  .stipple-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
    mix-blend-mode: screen;
    background-image:
      radial-gradient(circle at 50% 50%, var(--acid) 0.7px, transparent 1px),
      radial-gradient(circle at 30% 70%, var(--viol) 0.6px, transparent 1px);
    background-size: 6px 6px, 9px 9px;
    background-position: 0 0, 3px 4px;
    mask-image: radial-gradient(ellipse 75% 65% at 50% 50%, #000 0%, rgba(0,0,0,0.75) 45%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse 75% 65% at 50% 50%, #000 0%, rgba(0,0,0,0.75) 45%, transparent 85%);
  }
  .nonagon {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.35;
    mix-blend-mode: screen;
  }
  .nonagon svg { width: 100%; height: 100%; }
  .nonagon :global(.edge) {
    fill: none;
    stroke: var(--acid);
    stroke-width: 0.8;
    filter: drop-shadow(0 0 3px var(--acid));
  }
  .nonagon :global(.edge.v) {
    stroke: var(--viol);
    filter: drop-shadow(0 0 3px var(--viol));
  }
  .grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.08;
    mix-blend-mode: overlay;
    background-image: radial-gradient(rgba(236, 231, 220, 0.8) 0.5px, transparent 0.5px);
    background-size: 3px 3px;
    z-index: 2;
  }

  /* Mobile adjustments: drop rulers and stamps below 720px to avoid crowding */
  @media (max-width: 720px) {
    .hero {
      aspect-ratio: auto;
      min-height: 80vh;
      padding: var(--f-89) var(--f-21) var(--f-55);
    }
    .stamp-tl,
    .stamp-tr,
    .lbl-split,
    .ruler-top,
    .ruler-split,
    .ruler-bot {
      display: none;
    }
    .nav {
      position: static;
      margin-bottom: var(--f-34);
    }
    .nav ul {
      display: none;
    }
    .wm-box {
      position: static;
      height: auto;
      padding: var(--f-13) var(--f-21);
      margin: var(--f-34) 0;
    }
    .wm {
      font-size: clamp(20px, 8vw, 44px);
      letter-spacing: 0.32em;
    }
    .trib-box {
      position: static;
      height: auto;
      padding: var(--f-13) var(--f-21);
      flex-wrap: wrap;
    }
    .trib-box .t {
      font-size: 18px;
      letter-spacing: 0.3em;
    }
    .trib-box .tmark {
      font-size: 26px;
    }
  }
</style>
