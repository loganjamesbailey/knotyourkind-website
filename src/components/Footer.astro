---
const year = new Date().getFullYear();
---

<footer class="foot">
  <span><b>⌁ KNOT·YOUR·KIND</b> · A TRIBUTE TO SLIPKNOT · © {year}</span>
  <span>
    <a href="https://www.facebook.com/KnotYourKindTribute" target="_blank" rel="noopener">FB</a>
    <span class="sep">·</span>
    <a href="https://www.instagram.com/knotyourkindtribute" target="_blank" rel="noopener">IG</a>
    <span class="sep">·</span>
    <a href="https://www.youtube.com/@knotyourkind" target="_blank" rel="noopener">YT</a>
    <span class="sep">·</span>
    <a href="https://www.tiktok.com/@knotyourkind" target="_blank" rel="noopener">TT</a>
    <span class="sep"> · </span>
    BOOKING · LEFT LANE COLLECTIVE
  </span>
</footer>

<style>
  .foot {
    padding: var(--f-55) var(--f-144);
    border-top: 1px solid var(--rust-dim);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--f-34);
    font: 400 11px/1.3 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .foot b {
    color: var(--rust);
    font-weight: 400;
  }
  .foot a {
    color: var(--bone);
    transition: color 140ms;
  }
  .foot a:hover {
    color: var(--rust);
  }
  .foot .sep {
    color: var(--ash-dim);
    margin: 0 6px;
  }

  @media (max-width: 720px) {
    .foot {
      padding: var(--f-34) var(--f-21);
      flex-direction: column;
      gap: var(--f-13);
      align-items: flex-start;
    }
  }
</style>
