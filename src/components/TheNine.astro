---
import { Image } from 'astro:assets';
import m0 from '../assets/members/0.png';
import m1 from '../assets/members/1.png';
import m2 from '../assets/members/2.png';
import m3 from '../assets/members/3.png';
import m4 from '../assets/members/4.png';
import m5 from '../assets/members/5.png';
import m6 from '../assets/members/6.png';
import m7 from '../assets/members/7.png';
import m8 from '../assets/members/8.png';

// Roles mirror Slipknot's lineup numbering (#0–#8) — the numeric signature of the tribute.
const members = [
  { num: '01', label: '.01', role: 'TURNTABLES', roman: '·I·', image: m0 },
  { num: '02', label: '.02', role: 'DRUMS', roman: '·II·', image: m1 },
  { num: '03', label: '.03', role: 'BASS', roman: '·III·', image: m2 },
  { num: '04', label: '.04', role: 'PERCUSSION', roman: '·IV·', image: m3 },
  { num: '05', label: '.05', role: 'GUITAR', roman: '·V·', image: m4 },
  { num: '06', label: '.06', role: 'SAMPLES', roman: '·VI·', image: m5 },
  { num: '07', label: '.07', role: 'PERCUSSION', roman: '·VII·', image: m6 },
  { num: '08', label: '.08', role: 'GUITAR', roman: '·VIII·', image: m7 },
  { num: '09', label: '.09', role: 'VOX', roman: '·IX·', image: m8 },
];
---

<section class="sec reveal" id="the-nine">
  <div class="sec-inner">
    <div class="sec-head">
      <h2>THE <em>NINE</em></h2>
      <span class="stamp"><b>§·01</b> · 09 MASKED PERSONAE</span>
    </div>
    <div class="grid9">
      {members.map((m) => (
        <div class="tile mem">
          <Image
            src={m.image}
            alt={`Knot Your Kind member ${m.num} — ${m.role}`}
            widths={[360, 480, 720]}
            sizes="(max-width: 720px) 33vw, (max-width: 1280px) 30vw, 460px"
            loading="lazy"
          />
          <span class="corner">{m.label}</span>
          <span class="no">{m.num}</span>
          <span class="role"><span>{m.role}</span><span>{m.roman}</span></span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sec {
    padding: var(--f-144) 0;
    border-top: 1px solid var(--rust-dim);
    position: relative;
  }
  .sec::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: var(--rust);
    opacity: 0.5;
  }
  .sec-inner {
    max-width: var(--f-1597);
    margin: 0 auto;
    padding: 0 var(--f-144);
  }
  .sec-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--f-21);
    margin-bottom: var(--f-55);
    flex-wrap: wrap;
  }
  .sec-head h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(44px, 9vw, 89px);
    margin: 0;
    letter-spacing: 0.04em;
  }
  .sec-head h2 em {
    font-style: normal;
    background: linear-gradient(92deg, var(--acid), var(--viol));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 0 10px rgba(155, 255, 58, 0.25));
  }
  .stamp {
    font: 400 11px/1.3 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .stamp b { color: var(--rust); font-weight: 400; }

  .grid9 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--f-21);
  }
  .tile {
    position: relative;
    background:
      repeating-linear-gradient(135deg, rgba(236, 231, 220, 0.035) 0 1px, transparent 1px 10px),
      #0a0a0a;
    border: 1px solid var(--ash-dim);
    overflow: hidden;
  }
  .mem {
    aspect-ratio: 1 / 1.618;
  }
  .mem :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(0.25) brightness(0.8) contrast(1.05);
    transition: filter 600ms ease, transform 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .mem:hover :global(img) {
    filter: grayscale(0) brightness(1) contrast(1);
    transform: scale(1.03);
  }
  .mem::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.1) 40%, transparent 100%);
    pointer-events: none;
  }
  .mem .corner {
    position: absolute;
    top: var(--f-13);
    left: var(--f-13);
    font: 400 11px/1 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.14em;
    z-index: 2;
  }
  .mem .no {
    position: absolute;
    top: var(--f-21);
    left: var(--f-21);
    margin-top: var(--f-21);
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(48px, 6vw, 89px);
    color: var(--rust);
    line-height: 1;
    z-index: 2;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.85);
  }
  .mem .role {
    position: absolute;
    bottom: var(--f-21);
    left: var(--f-21);
    right: var(--f-21);
    display: flex;
    justify-content: space-between;
    font: 400 11px/1 var(--font-mono);
    color: var(--bone);
    letter-spacing: 0.16em;
    z-index: 2;
  }

  @media (max-width: 720px) {
    .sec {
      padding: var(--f-55) 0;
    }
    .sec-inner {
      padding: 0 var(--f-21);
    }
    .grid9 {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--f-5);
    }
    .mem .no {
      font-size: 32px;
    }
    .mem .role {
      font-size: 9px;
      letter-spacing: 0.1em;
    }
  }
</style>
