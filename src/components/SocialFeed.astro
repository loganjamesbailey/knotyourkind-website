---
// Juicer social feed — preserved from current site, restyled to WF-A vocabulary.
// Feed ID: knot-your-kind-a-tribute-to-slipknot
---

<section class="sec reveal" id="social">
  <div class="sec-inner">
    <div class="sec-head">
      <h2>LATEST <em>POSTS</em></h2>
      <span class="stamp"><b>§·05</b> · AGGREGATED · IG · FB · TT · YT</span>
    </div>
    <div class="feed-wrap">
      <link rel="stylesheet" href="https://www.juicer.io/api/feeds/knot-your-kind-a-tribute-to-slipknot/stylesheet.css" />
      <script async defer src="https://www.juicer.io/api/feeds/knot-your-kind-a-tribute-to-slipknot/iframe.js"></script>
      <ul class="juicer-feed" data-feed-id="knot-your-kind-a-tribute-to-slipknot" data-per="9" data-truncate="125"></ul>
    </div>
  </div>
</section>

<style is:global>
  /* Juicer embed overrides — match WF-A Meridian vocabulary */
  #juicer-feed h1.referral,
  .j-paginate {
    display: none !important;
  }
  .juicer-feed {
    padding: 0 !important;
  }
  .j-poster,
  .j-twitter-poster {
    color: var(--rust) !important;
    font-family: var(--font-mono) !important;
    letter-spacing: 0.14em !important;
  }
  .j-message,
  .j-text p {
    font-family: var(--font-display) !important;
    color: var(--bone) !important;
    font-size: 15px !important;
    font-weight: 300 !important;
    line-height: 1.5 !important;
  }
  .j-date {
    font-family: var(--font-mono) !important;
    color: var(--ash) !important;
    font-size: 11px !important;
    letter-spacing: 0.14em !important;
  }
  .feed-item {
    background: var(--ink-2) !important;
    border: 1px solid var(--ash-dim) !important;
    border-radius: 0 !important;
    transition: border-color 220ms ease !important;
  }
  .feed-item:hover {
    border-color: var(--rust) !important;
  }
  .j-meta a {
    color: var(--rust) !important;
  }
</style>

<style>
  .sec {
    padding: var(--f-144) 0;
    border-top: 1px solid var(--rust-dim);
    position: relative;
  }
  .sec::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: var(--rust);
    opacity: 0.5;
  }
  .sec-inner {
    max-width: var(--f-1597);
    margin: 0 auto;
    padding: 0 var(--f-144);
  }
  .sec-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--f-21);
    margin-bottom: var(--f-55);
    flex-wrap: wrap;
  }
  .sec-head h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(44px, 9vw, 89px);
    margin: 0;
    letter-spacing: 0.04em;
  }
  .sec-head h2 em {
    font-style: normal;
    color: var(--rust);
  }
  .stamp {
    font: 400 11px/1.3 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .stamp b { color: var(--rust); font-weight: 400; }

  @media (max-width: 960px) {
    .sec-inner { padding: 0 var(--f-21); }
    .sec { padding: var(--f-55) 0; }
  }
</style>
