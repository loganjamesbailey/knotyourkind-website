---
import { Image } from 'astro:assets';
import bandLive from '../assets/band-live.png';

export interface Props {
  /** Optional MP4 video source — e.g. "/video/hero.mp4". When absent, renders the still image. */
  videoSrc?: string;
  poster?: string;
}

const { videoSrc, poster = bandLive.src } = Astro.props;
---

<section class="film reveal" aria-label="Live motion reference">
  {videoSrc ? (
    <video
      class="vid"
      data-src={videoSrc}
      poster={poster}
      muted
      loop
      playsinline
      preload="none"
    ></video>
  ) : (
    <Image src={bandLive} alt="Knot Your Kind — live" class="vid still" widths={[1280, 1920, 2560]} sizes="100vw" loading="lazy" />
  )}
  <div class="cap">§·02 · MOTION · LOOP · MUTED</div>
  <div class="rt">1597 × 610<br />÷φ⁰ → 610 (÷φ²)</div>
</section>

<script>
  // Lazy-hydrate the video only when in viewport, and only if motion is allowed.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const video = document.querySelector<HTMLVideoElement>('.film video[data-src]');
  if (video && !reduced) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const src = video.getAttribute('data-src');
          if (src) {
            video.src = src;
            video.play().catch(() => {});
          }
          io.unobserve(video);
        }
      }
    });
    io.observe(video);
  }
</script>

<style>
  .film {
    position: relative;
    width: 100%;
    height: 610px;
    max-height: 62vh;
    overflow: hidden;
    border-top: 1px solid var(--ash-dim);
    border-bottom: 1px solid var(--ash-dim);
  }
  .vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.15) contrast(1.1) brightness(0.7);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(155, 255, 58, 0.18), transparent 55%),
      radial-gradient(ellipse at 70% 50%, rgba(184, 77, 255, 0.18), transparent 55%),
      #070707;
  }
  .film::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.55));
    pointer-events: none;
  }
  .cap {
    position: absolute;
    bottom: var(--f-34);
    left: var(--f-34);
    font: 400 11px/1.4 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.2em;
    z-index: 2;
    text-transform: uppercase;
  }
  .rt {
    position: absolute;
    bottom: var(--f-34);
    right: var(--f-34);
    font: 400 11px/1.4 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    z-index: 2;
    text-align: right;
  }

  @media (max-width: 720px) {
    .film { height: 360px; }
    .cap, .rt {
      bottom: var(--f-13);
      left: var(--f-13);
      font-size: 10px;
    }
    .rt { left: auto; right: var(--f-13); }
  }
</style>
