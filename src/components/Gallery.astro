---
import { Image } from 'astro:assets';
import bandLive from '../assets/band-live.png';
import bandPoster from '../assets/band-poster.png';
import m8 from '../assets/members/8.png';
import m4 from '../assets/members/4.png';
import m1 from '../assets/members/1.png';

const tiles = [
  { key: 't1', corner: 'A · 610×1220', label: 'COVER PLATE', n: '01', img: bandLive, alt: 'Knot Your Kind — cover plate' },
  { key: 't2', corner: 'B · 377×610', label: 'PORTRAIT', n: '02', img: m8, alt: 'Knot Your Kind — #9 vocalist portrait' },
  { key: 't3', corner: 'C · 377×377', label: 'STAGE', n: '03', img: bandPoster, alt: 'Knot Your Kind — stage poster' },
  { key: 't4', corner: 'D · 233×610', label: 'DETAIL', n: '04', img: m4, alt: 'Knot Your Kind — #5 guitar detail' },
  { key: 't5', corner: 'E · 233×377', label: 'DETAIL', n: '05', img: m1, alt: 'Knot Your Kind — #2 drums detail' },
];
---

<section class="sec reveal" id="gallery">
  <div class="sec-inner">
    <div class="sec-head">
      <h2><em>GALLERY</em></h2>
      <span class="stamp"><b>§·04</b> · {String(tiles.length).padStart(2, '0')}·PLATES</span>
    </div>
    <div class="gal-grid">
      {tiles.map((t) => (
        <div class={`tile ${t.key}`}>
          <Image
            src={t.img}
            alt={t.alt}
            widths={[480, 720, 1080, 1440]}
            sizes="(max-width: 720px) 100vw, (max-width: 1280px) 50vw, 33vw"
            loading="lazy"
          />
          <span class="corner">{t.corner}</span>
          <div class="lbl"><span>{t.label}</span><b>{t.n}</b></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sec {
    padding: var(--f-144) 0;
    border-top: 1px solid var(--rust-dim);
    position: relative;
  }
  .sec::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: var(--rust);
    opacity: 0.5;
  }
  .sec-inner {
    max-width: var(--f-1597);
    margin: 0 auto;
    padding: 0 var(--f-144);
  }
  .sec-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--f-21);
    margin-bottom: var(--f-55);
    flex-wrap: wrap;
  }
  .sec-head h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(44px, 9vw, 89px);
    margin: 0;
    letter-spacing: 0.04em;
  }
  .sec-head h2 em {
    font-style: normal;
    background: linear-gradient(92deg, var(--acid), var(--viol));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(0 0 10px rgba(155, 255, 58, 0.25));
  }
  .stamp {
    font: 400 11px/1.3 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .stamp b { color: var(--rust); font-weight: 400; }

  .gal-grid {
    display: grid;
    grid-template-columns: 610fr 377fr 233fr;
    grid-template-rows: 610px 377px;
    gap: var(--f-13);
  }
  .gal-grid .t1 { grid-column: 1; grid-row: 1 / span 2; }
  .gal-grid .t2 { grid-column: 2; grid-row: 1; }
  .gal-grid .t3 { grid-column: 2; grid-row: 2; }
  .gal-grid .t4 { grid-column: 3; grid-row: 1; }
  .gal-grid .t5 { grid-column: 3; grid-row: 2; }

  .tile {
    position: relative;
    background:
      repeating-linear-gradient(135deg, rgba(236, 231, 220, 0.035) 0 1px, transparent 1px 10px),
      #0a0a0a;
    border: 1px solid var(--ash-dim);
    overflow: hidden;
  }
  .tile :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) brightness(0.85) contrast(1.05);
    transition: filter 600ms ease, transform 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .tile:hover :global(img) {
    filter: grayscale(0) brightness(1) contrast(1);
    transform: scale(1.04);
  }
  .tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65), transparent 60%);
    pointer-events: none;
  }
  .tile .corner {
    position: absolute;
    top: var(--f-13);
    left: var(--f-13);
    font: 400 11px/1 var(--font-mono);
    color: var(--rust);
    letter-spacing: 0.14em;
    z-index: 2;
  }
  .tile .lbl {
    position: absolute;
    bottom: var(--f-13);
    left: var(--f-13);
    right: var(--f-13);
    display: flex;
    justify-content: space-between;
    gap: var(--f-13);
    font: 400 11px/1 var(--font-mono);
    color: var(--ash);
    letter-spacing: 0.14em;
    z-index: 2;
    text-transform: uppercase;
  }
  .tile .lbl b { color: var(--rust); font-weight: 400; }

  @media (max-width: 960px) {
    .sec-inner { padding: 0 var(--f-21); }
    .sec { padding: var(--f-55) 0; }
    .gal-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 377px 233px 233px;
      gap: var(--f-5);
    }
    .gal-grid .t1 { grid-column: 1 / -1; grid-row: 1; }
    .gal-grid .t2 { grid-column: 1; grid-row: 2; }
    .gal-grid .t3 { grid-column: 2; grid-row: 2; }
    .gal-grid .t4 { grid-column: 1; grid-row: 3; }
    .gal-grid .t5 { grid-column: 2; grid-row: 3; }
  }
</style>
