{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/drafting/**",
              "components/forms/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Share Tech Mono|Oswald))/i]",
        "message": "Font not provided by the design system. Available: Share Tech Mono, Oswald."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|subject)$/]",
        "message": "<Button> variant must be one of 'default' | 'subject'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|lineLength|rise|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: label, lineLength, rise, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dimension'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|width|style|key|ref|className|style|children)$/]",
        "message": "<Dimension> doesn't accept that prop. Declared props: value, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|name|type|textarea|placeholder|required|rows|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, name, type, textarea, placeholder, required, rows, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nonagram'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|weight|showConstruction|style|key|ref|className|style|children)$/]",
        "message": "<Nonagram> doesn't accept that prop. Declared props: size, weight, showConstruction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nonagram'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:hair|subject)$/]",
        "message": "<Nonagram> weight must be one of 'hair' | 'subject'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NotesList'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|notes|style|key|ref|className|style|children)$/]",
        "message": "<NotesList> doesn't accept that prop. Declared props: title, notes, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RevisionTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|onRowClick|style|key|ref|className|style|children)$/]",
        "message": "<RevisionTable> doesn't accept that prop. Declared props: columns, rows, onRowClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SheetFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|style|className|key|ref|className|style|children)$/]",
        "message": "<SheetFrame> doesn't accept that prop. Declared props: children, padding, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|angle|size|style|key|ref|className|style|children)$/]",
        "message": "<Stamp> doesn't accept that prop. Declared props: children, color, angle, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:red|graphite)$/]",
        "message": "<Stamp> color must be one of 'red' | 'graphite'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stamp'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Stamp> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TitleBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|drawnBy|drawnByLabel|date|scale|sheet|style|key|ref|className|style|children)$/]",
        "message": "<TitleBlock> doesn't accept that prop. Declared props: title, drawnBy, drawnByLabel, date, scale, sheet, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
