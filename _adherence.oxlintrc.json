      "--graphite-2",
      "--graphite-3",
      "--graphite-4",
      "--leading-note",
      "--line-construction",
      "--line-standard",
      "--line-subject",
      "--line-w-hair",
      "--line-w-subject",
      "--paper-1",
      "--paper-2",
      "--paper-3",
      "--paper-tooth",
      "--radius-none",
      "--shadow-sheet",
      "--sheet-border-gap",
      "--sheet-margin",
      "--space-1",
